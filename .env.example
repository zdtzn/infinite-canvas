IMAGE_REPOSITORY=ghcr.io/zdtzn/infinite-canvas
# 正式环境推荐固定 v0.x.x；确认新版本后再修改，不建议长期使用 latest。
IMAGE_TAG=latest

# 使用 HTTPS profile 时填写已解析到服务器公网 IP 的域名。
DOMAIN=canvas.example.com
PUBLIC_BASE_URL=https://canvas.example.com

# 首次部署生成后保持不变，例如：openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret

JOB_CONCURRENCY=2
UPSTREAM_TIMEOUT_MS=600000
# 单个用户可保存的服务端素材总量，默认 2 GiB（字节）。
MAX_USER_ASSET_BYTES=2147483648
ANALYTICS_GA4_ID=
ANALYTICS_BAIDU_ID=
